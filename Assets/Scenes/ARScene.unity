  planetPrefab: {fileID: 1856687845478954, guid: ab152f61198d54532ae39108e616ff59, type: 3}
  planetInfo: '<b><u>Mercury</u></b><br>

    Mercury is the closest planet to the
    Sun and the smallest planet.<br>

    Distance from Sun: <b>~58 million km</b><br>

    Orbital
    speed: <b>47 km/s</b> (fastest planet)<br>

    A year on Mercury is only <b>88
    Earth days</b>.<br>

    It has no atmosphere, so temperatures vary extremely.<br><br>'
  planetName: Mercury
